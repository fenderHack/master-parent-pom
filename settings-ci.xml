<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              http://maven.apache.org/xsd/settings-1.0.0.xsd">

    <!--
        Fichier Maven settings pour CI/CD et développement local.
        Ne jamais mettre de credentials en dur ici — utiliser les variables d'env.

        Variables requises :
          ANYPOINT_USERNAME   login Anypoint Platform
          ANYPOINT_PASSWORD   mot de passe Anypoint Platform
    -->
    <servers>

        <server>
            <id>anypoint-exchange-v3</id>
            <username>${env.ANYPOINT_USERNAME}</username>
            <password>${env.ANYPOINT_PASSWORD}</password>
        </server>

        <server>
            <id>MuleRepository</id>
            <username>${env.ANYPOINT_USERNAME}</username>
            <password>${env.ANYPOINT_PASSWORD}</password>
        </server>

        <server>
            <id>mulesoft-ee-releases</id>
            <username>${env.ANYPOINT_USERNAME}</username>
            <password>${env.ANYPOINT_PASSWORD}</password>
        </server>

    </servers>

</settings>
